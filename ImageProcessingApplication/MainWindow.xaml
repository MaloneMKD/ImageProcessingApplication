<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ImageProcessingApplication.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageProcessingApplication"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ImageProcessingApplication">

    <Grid x:Name="MainGrid" Loaded="MainGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!--Controls-->
        <Grid Margin="0, 10" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="ProcessComboBox" Grid.Row="1" Grid.Column="0" Header="Process" FontSize="12" SelectionChanged="ProcessComboBox_SelectionChanged" MinWidth="100"
                      Margin="10, 0" VerticalAlignment="Bottom">
                <ComboBox.Items>
                    <ComboBoxItem>Merge</ComboBoxItem>
                    <ComboBoxItem>Logic AND</ComboBoxItem>
                    <ComboBoxItem>Logic NAND</ComboBoxItem>
                    <ComboBoxItem>Logic OR</ComboBoxItem>
                    <ComboBoxItem>Logic XOR</ComboBoxItem>
                    <ComboBoxItem>Addition</ComboBoxItem>
                    <ComboBoxItem>Subtraction</ComboBoxItem>
                    <ComboBoxItem>Multiplication</ComboBoxItem>
                    <ComboBoxItem>Linear Contrast</ComboBoxItem>
                    <ComboBoxItem>Calculate Contrast</ComboBoxItem>
                    <ComboBoxItem>Luminance</ComboBoxItem>
                    <ComboBoxItem>Gauss Filter</ComboBoxItem>
                    <ComboBoxItem>Smoothing Filter</ComboBoxItem>
                    <ComboBoxItem>Sharpen</ComboBoxItem>
                    <ComboBoxItem>Edge Detect</ComboBoxItem>
                    <ComboBoxItem>Robert Filter</ComboBoxItem>
                    <ComboBoxItem>Prewitt Filter</ComboBoxItem>
                    <ComboBoxItem>Sobel Filter</ComboBoxItem>
                    <ComboBoxItem>Laplace Convolution</ComboBoxItem>
                    <ComboBoxItem>Erosion</ComboBoxItem>
                    <ComboBoxItem>H-Flip</ComboBoxItem>
                    <ComboBoxItem>V-Flip</ComboBoxItem>
                    <ComboBoxItem>R-Rotate</ComboBoxItem>
                    <ComboBoxItem>L-Rotate</ComboBoxItem>
                    <ComboBoxItem>Brightness</ComboBoxItem>
                    <ComboBoxItem>Filtering</ComboBoxItem>
                    <ComboBoxItem>Linear Contrast Saturation</ComboBoxItem>
                    <ComboBoxItem>ScalingNN</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>

            <!--File Path Inputs-->
            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Bottom" ColumnSpacing="15" Margin="10, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <Grid x:Name="FileInput1Panel" VerticalAlignment="Bottom" Grid.Column="0" ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="BrowseFilesButton1" Grid.Column="0" FontSize="10" VerticalAlignment="Bottom" Click="BrowseFilesButton1_Click">
                        <FontIcon Glyph="&#xEC50;" />
                    </Button>
                    <TextBox Grid.Column="1" x:Name="FileName1_textbox" Header="Image Path:" FontSize="12" IsReadOnly="True" />
                </Grid>

                <Grid x:Name="FileInput2Panel" VerticalAlignment="Bottom" Grid.Column="1" ColumnSpacing="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="BrowseFilesButton2" Grid.Column="0" FontSize="10" VerticalAlignment="Bottom" Click="BrowseFilesButton2_Click">
                        <FontIcon Glyph="&#xEC50;" />
                    </Button>
                    <TextBox x:Name="FileName2_textBox" Grid.Column="1" Header="Image Path:" FontSize="12" MinWidth="300" IsReadOnly="True"/>
                </Grid>
            </Grid>

            <!--Arguments-->
            <Border x:Name="ArgumentsBorder" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Padding="20, 5" BorderBrush="SlateGray" BorderThickness="1" CornerRadius="5"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10, 0">
                
                <Grid ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox  x:Name="NumberInput1" Grid.Column="0" Header="Input 1" MinWidth="100" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox  x:Name="NumberInput2" Grid.Column="1" Header="Input 2" MinWidth="100" VerticalAlignment="Center" FontSize="12"/>
                    <TextBox  x:Name="NumberInput3" Grid.Column="2" Header="Input 3" MinWidth="100" VerticalAlignment="Center" FontSize="12"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="2" Margin="10, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                
                <CheckBox x:Name="ShowInputImages" Grid.Row="1" Content="Show Input Images" FontSize="12" Margin="10, 0" VerticalAlignment="Bottom"
                      Checked="ShowInputImages_Checked" Unchecked="ShowInputImages_Unchecked" IsChecked="True" HorizontalAlignment="Right"/>
                <Button x:Name="ProcessButton" Grid.Row="1" Grid.Column="4" Content="Process" FontSize="12" MinWidth="100" Margin="10, 0" 
                        VerticalAlignment="Bottom" HorizontalAlignment="Right" Click="ProcessButton_Click"/>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="White">
            <Grid x:Name="ImageGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="Input1ImageBorder" Grid.Column="0" BorderBrush="Maroon" BorderThickness="5">
                    <Image x:Name="Input1Image" Stretch="Uniform"/>
                </Border>

                <Border x:Name="Input2ImageBorder" Grid.Column="1" BorderBrush="Olive" BorderThickness="5">
                    <Image x:Name="Input2Image" Stretch="Uniform"/>
                </Border>
                <Border x:Name="OutputImageBorder" Grid.Column="2" BorderBrush="SlateGray" BorderThickness="5">
                    <Image x:Name="OutputImage" Stretch="Uniform"/>
                </Border>
            </Grid>
        </Border>
        
        <!--Loading Animation-->   
        <Grid x:Name="LoadingGrid" Grid.Row="1" Visibility="Collapsed" Background="#AA444444" RowSpacing="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            
            <ProgressRing Grid.Row="0" IsIndeterminate="True" Foreground="White" VerticalAlignment="Bottom"/>
            <TextBlock x:Name="BusyText" Grid.Row="1" Text="Loading..." FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</Window>
